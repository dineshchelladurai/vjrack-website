# ─── Required ───────────────────────────────────────────────────────────────
# Admin password hash (bcrypt). Generate with:
#   node -e "require('bcryptjs').hash('your-secure-password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=

# ─── Optional ───────────────────────────────────────────────────────────────
# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# ─── Frontend (VITE_ prefix exposes to client) ─────────────────────────────
# Web3Forms access key for contact form (get free at https://web3forms.com)
VITE_WEB3FORMS_ACCESS_KEY=

# Google Maps / Forge API (only if using Map component)
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
