# ─── Required ───────────────────────────────────────────────────────────────
# Note: Admin password will be auto-generated on first startup if missing


# ─── Optional ───────────────────────────────────────────────────────────────
# Server port (default: 5000)
PORT=5000

# Node environment
NODE_ENV=production

# ─── Email SMTP (For Admin Password Recovery) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ─── Frontend (VITE_ prefix exposes to client) ─────────────────────────────
# (No frontend keys currently required)

# Google Maps / Forge API (only if using Map component)
# VITE_FRONTEND_FORGE_API_KEY=
# VITE_FRONTEND_FORGE_API_URL=
